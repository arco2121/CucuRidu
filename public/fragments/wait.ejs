<div class="flex_gap_30 game_main_con">
        <div class="column sour_gummy_regular flex_gap_25 wait_code_con">
            <div class="column flex_gap_10">
                <div class="row wait_code_text flex_gap_10">
                    <h4>Codice Stanza: </h4><h4 class="selectable sour_gummy_bold"> <%= stanzaId %></h4>
                </div>
                <button class="button btn_smallText btn_style_1 sour_gummy_bold btn_doubleBorder" id="shareButton">Condividi</button>
            </div>
            <div class="column flex_gap_10">
                <% if (interroghi) { %>
                    <button class="button btn_bigText btn_style_2 sour_gummy_bold btn_doubleBorder" id="startButton"><%= primoRound ? "Inizia" : "Continua" %></button>
                    <% if(primoRound) {%>
                        <button class="button btn_mediumText btn_style_3 sour_gummy_bold btn_doubleBorder" id="packsButton">Espansioni</button>
                    <% } %>
                <% } %>
                <% if(!primoRound && seiMaster) { %>
                    <button class="button btn_bigText btn_style_1 sour_gummy_bold btn_doubleBorder" id="chiudiButton">Termina</button>
                <% } %>
            </div>

        </div>
        <div class="column wait_players_list flex_gap_15 btn_doubleBorder">
            <h1 class="sour_gummy_bold wait_players_list_title" id="numeroGiocatori">Giocatori presenti: 0</h1>
            <h4 class="sour_gummy_bold" id="attesa"></h4>
            <div class="wait_players_list_hr"></div>
            <div class="appear" id="showGiocatori">

            </div>
        </div>

</div>

<script src="<%= scripts %>/fragments/wait.js"></script>