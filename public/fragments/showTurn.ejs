<div class="flex_gap_30 game_main_con">
    <div class="column sour_gummy_regular flex_gap_25 wait_code_con">
        <div class="column flex_gap_10">
            <div id="<%= domanda[1] %>" class="card domanda">
                <%= domanda[0] %>
            </div>
        </div>
    </div>
    <% if(risposte) { %>
        <div class="column wait_players_list flex_gap_15 btn_doubleBorder">
            <div id="showCards">
                <% risposte.forEach((risposta, index) => { %>
                    <div class="card risposta" id="<%= index %>"><%= risposta %></div>
                <% }); %>
            </div>
        </div>
        <button id="sendCards">Conferma</button>
    <% } else { %>
        <h1>Aspetta che tutti finiscano di rispondere</h1>
    <% } %>
</div>

<script>
    const cards = document.querySelectorAll(".risposta");
    const domandaAttuale = document.querySelector(".domanda");
    const sendCards = document.getElementById("sendCards");
    const defaultText = domandaAttuale.textContent.trim();
    const risposteDate = Array.from({ length: parseInt(domandaAttuale.id) }, () => null);

    const toggleCards = (target) => {
        if(risposteDate.length > 2) return;
        if(risposteDate.indexOf(target.textContent) !== -1)
            risposteDate[risposteDate.indexOf(target.textContent)] = null;
        else
            risposteDate[risposteDate.findIndex(ele => ele === null)] = target.textContent;
        const risposteAttuali = risposteDate.filter(ele => ele !== null).length;
        if(risposteAttuali > 0) {
            let initText = defaultText;
            risposteDate.filter(risposta => risposta !== null).forEach(risposta => initText = (initText[0] === "_"  || initText[(initText.indexOf("_") - 1)] === ".") ? initText.replace("_", risposta) :
                initText.replace("_", risposta[0].toLowerCase() + risposta.slice(1, risposta.length)));
            domandaAttuale.textContent = initText;
        }
        else
            domandaAttuale.textContent = defaultText;
        target.classList.toggle("selected");
    };

    cards.forEach(card => card.addEventListener("click", (e) => toggleCards(e.target)));

    sendCards?.addEventListener("click", () => {
        if(risposteDate.filter(ele => ele === null).length > 0) {
            alert("Finisci di selezionare le risposte, mongolo");
            return;
        }
        socket.emit("inviaRisposta", {
            id: referenceStanza,
            indexCarte: risposteDate.map(risposta => referenceGiocatore.mazzo.indexOf(risposta))
        });
    });
</script>