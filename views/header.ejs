<!doctype html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport"
          content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <meta name="dataFromBackEnd" content="<%= JSON.stringify(params) %>">
    <link rel="manifest" href="/manifest.json">
    <link rel="stylesheet" href="/style/global.css">
    <link rel="stylesheet" href="/style/<%= page %>.css">
    <link rel="icon" href="/assets/icon.png">
    <title>Cucu Ridu</title>
</head>
<body>
<script>
    // Forza la riparazione PRIMA di ogni altra cosa
    (function() {
        console.log("Inizio riparazione manuale...");

        // 1. Ripara .remove()
        if (!Element.prototype.remove) {
            Element.prototype.remove = function() {
                if (this.parentNode) this.parentNode.removeChild(this);
            };
        }

        // 2. Ripara AudioContext
        window.AudioContext = window.AudioContext || window.webkitAudioContext || function() {
            this.createBufferSource = function() {};
            this.decodeAudioData = function() {};
        };

        // 3. Ripara CustomEvent e Event (per l'errore "Invalid Argument")
        try {
            new CustomEvent('test');
        } catch (e) {
            var CustomEventPolyfill = function (event, params) {
                params = params || { bubbles: false, cancelable: false, detail: undefined };
                var evt = document.createEvent('CustomEvent');
                evt.initCustomEvent(event, params.bubbles, params.cancelable, params.detail);
                return evt;
            };
            CustomEventPolyfill.prototype = window.Event.prototype;
            window.CustomEvent = CustomEventPolyfill;
            window.Event = CustomEventPolyfill;
        }

        // 4. Ripara classList (versione super compatibile)
        if (!("classList" in document.documentElement)) {
            // Se manca proprio classList (molto raro ma possibile su vecchie TV)
            // qui servirebbe un polyfill esterno pesante, ma solitamente basta
            // gestire gli argomenti multipli come hai già fatto.
        }

        var t = document.createElement("_");
        t.classList.add("a", "b");
        if (!t.classList.contains("b")) {
            var a = DOMTokenList.prototype.add;
            DOMTokenList.prototype.add = function() {
                for (var i = 0; i < arguments.length; i++) a.call(this, arguments[i]);
            };
        }

        console.log("Riparazione completata.");
    })();
</script>
    <%- include("components/legacySupport") %>
    <script src="<%= scripts %>/config/colorConfig.js"></script>
    <%- include("components/loadScreen") %>
    <script src="<%= scripts %>/config/registerWorker.js"></script>
    <script src="<%= scripts %>/ejs.js"></script>
    <script src="<%= scripts %>/config/globalConfig.js"></script>
    <script src="<%= scripts %>/config/eventsConfig.js"></script>
    <script src="<%= scripts %>/config/midleChecks.js"></script>
    <script src="<%= scripts %>/config/manageBack.js"></script>
    <%- include(page, params) %>
    <%- include("components/audioManager", { bgm: params.bgm || "GameMusic-Candy_Bazaar" }) %>
    <script src="<%= scripts %>/config/clearDom.js"></script>

    <noscript><%- include("error", { error: 2096, message: "Javascript not supported" })%></noscript>
</body>
</html>