<% if(legacy) { %>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/core-js/3.36.1/minified.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/regenerator-runtime@0.14.1/runtime.js"></script>

    <script>
        window.onerror = function(message, source, lineno, colno, error) {
            var fileName = source ? source.split('/').pop() : "Script sconosciuto";
            var message = "FILE: " + fileName + "\n" +
                "ERRORE: " + message + "\n" +
                "RIGA: " + lineno + "\n" +
                "COLONNA: " + colno;
            alert(message);
            console.error(message);
            return true;
        };
    </script>
<% } %>